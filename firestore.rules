rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // ═══ المنتجات — قراءة عامة، كتابة للمسجلين فقط (الأدمن يكتب من الكود مباشرة) ═══
    match /products/{productId} {
      allow read: if true;
      allow write: if isLoggedIn();
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isLoggedIn();
        allow delete: if isLoggedIn() && isOwner(resource.data.uid);
      }
    }

    // ═══ الباقات ═══
    match /packages/{packageId} {
      allow read: if true;
      allow write: if isLoggedIn();
    }

    // ═══ الإعدادات ═══
    match /settings/{doc} {
      allow read: if true;
      allow write: if isLoggedIn();
    }

    // ═══ الشحن ═══
    match /shipping/{doc} {
      allow read: if true;
      allow write: if isLoggedIn();
    }

    // ═══ العملات ═══
    match /currencies/{doc} {
      allow read: if true;
      allow write: if isLoggedIn();
    }

    // ═══ كودات الخصم — القراءة للتحقق من الكود فقط ═══
    match /promocodes/{doc} {
      allow read: if true;
      allow write: if isLoggedIn();
    }

    // ═══ الطلبات — الإنشاء مفتوح، التعديل والحذف للمستخدم صاحب الطلب فقط ═══
    match /orders/{orderId} {
      allow read: if isLoggedIn() && (
        isOwner(resource.data.customer.uid) ||
        request.auth.token.email == 'admin@aromena.com'
      );
      allow create: if true;
      allow update: if isLoggedIn() && isOwner(resource.data.customer.uid);
      allow delete: if isLoggedIn();
    }

    // ═══ المستخدمون — كل مستخدم يقرأ ويعدل بياناته فقط ═══
    match /users/{userId} {
      allow read: if isLoggedIn() && isOwner(userId);
      allow create: if isLoggedIn() && isOwner(userId);
      allow update: if isLoggedIn() && isOwner(userId);
      allow delete: if false;
    }

    // ═══ طلبات الجملة — الإنشاء مفتوح ═══
    match /wholesale/{doc} {
      allow read: if isLoggedIn();
      allow create: if true;
      allow update, delete: if isLoggedIn();
    }

    // ═══ الزوار — إحصائيات فقط ═══
    match /visitors/{doc} {
      allow read: if isLoggedIn();
      allow create, update: if true;
      allow delete: if false;
    }

    // ═══ النشرة البريدية ═══
    match /newsletter/{doc} {
      allow read: if isLoggedIn();
      allow create: if true;
      allow update, delete: if isLoggedIn();
    }

    // ═══ التسويق ═══
    match /marketing/{doc} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn();
    }

    // ═══ رسائل البوابة ═══
    match /portal_nachrichten/{doc} {
      allow read, write: if isLoggedIn();
    }

    match /portal_anfragen/{doc} {
      allow read, write: if isLoggedIn();
    }

    // ═══ نقاط البيع ═══
    match /locations/{doc} {
      allow read: if true;
      allow write: if isLoggedIn();
    }

    // ═══ سجلّ النشاط — تسجيل محاولات الدخول (الإنشاء مفتوح، لا تعديل/حذف) ═══
    match /activity_log/{doc} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // ═══ أي collection غير محددة — مرفوض ═══
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
