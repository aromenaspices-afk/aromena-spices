rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if true;
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isLoggedIn();
        allow delete: if isLoggedIn();
      }
    }

    match /packages/{packageId} {
      allow read: if true;
      allow write: if true;
    }

    match /settings/{doc} {
      allow read: if true;
      allow write: if true;
    }

    match /shipping/{doc} {
      allow read: if true;
      allow write: if true;
    }

    match /currencies/{doc} {
      allow read: if true;
      allow write: if true;
    }

    match /promocodes/{doc} {
      allow read: if true;
      allow write: if true;
    }

    match /orders/{orderId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }

    match /wholesale/{doc} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }

    match /visitors/{doc} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }

    match /newsletter/{doc} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }

    match /marketing/{doc} {
      allow read: if true;
      allow write: if true;
    }

    match /portal_nachrichten/{doc} {
      allow read, write: if isLoggedIn();
    }

    match /portal_anfragen/{doc} {
      allow read, write: if isLoggedIn();
    }

    match /locations/{doc} {
      allow read: if true;
      allow write: if true;
    }

    match /activity_log/{doc} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    match /abandoned_carts/{doc} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
